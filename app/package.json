{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "IS_NEXT_BUILD=true next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:smoke-models": "RUN_AGENT_SMOKE=1 vitest run src/test/agent-smoke.test.ts --reporter=verbose",
    "test:smoke-route": "RUN_LIVE_CHAT_ROUTE=1 vitest run src/test/live-chat-route.test.ts --reporter=verbose",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:encrypt-keys": "tsx src/scripts/encrypt-existing-keys.ts",
    "postbuild": "cp -r public .next/standalone/public && cp -r .next/static .next/standalone/.next/static && mkdir -p .next/standalone/node_modules/pdfjs-dist/legacy/build && cp node_modules/pdfjs-dist/legacy/build/pdf.worker.mjs .next/standalone/node_modules/pdfjs-dist/legacy/build/"
  },
  "dependencies": {
