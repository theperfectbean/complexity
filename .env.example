# Perplexity
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxx
# PERPLEXITY_API_BASE_URL=https://api.perplexity.ai/v1/responses
# PERPLEXITY_STREAM_TIMEOUT_MS=300000
# PERPLEXITY_WEB_TOOLS=web_search,fetch_url

# PostgreSQL
POSTGRES_USER=complexity
POSTGRES_PASSWORD=changeme
POSTGRES_DB=complexity
DATABASE_URL=postgresql://complexity:changeme@postgres:5432/complexity

# Auth.js
NEXTAUTH_SECRET=replace-with-32-char-random-string
NEXTAUTH_URL=http://localhost:3002
# AUTH_PASSWORD_MIN_LENGTH=8
# AUTH_PASSWORD_REQUIRE_COMPLEXITY=true  # Require at least one letter and one number
# AUTH_REQUIRE_EMAIL_VERIFICATION=false  # Set to true to require email verification before login
# AUTH_VERIFICATION_TOKEN_TTL_MS=86400000  # 24 hours
# AUTH_BCRYPT_COST=12
# AUTH_RESET_TOKEN_BYTES=32
# AUTH_RESET_TOKEN_TTL_MS=3600000
# AUTH_LOCALHOST_BASE_URL=localhost:3002
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# Embedder
EMBEDDER_URL=http://embedder:8000
# EMBEDDER_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDER_APP_TITLE=Complexity Embedder
# EMBEDDER_APP_VERSION=1.0.0

# Redis
REDIS_URL=redis://redis:6379
# REDIS_MAX_RETRIES_PER_REQUEST=1

# Chat Settings
# CHAT_RATE_LIMIT_PER_MINUTE=20
# CHAT_CACHE_TTL_SECONDS=3600
# CHAT_EMPTY_RESPONSE_FALLBACK_TEXT="I couldn't generate a response. Please try again."
# CHAT_MEMORY_EVENT_TIMEOUT_MS=1200
# CHAT_MAX_ATTACHMENT_BYTES=5242880

# RAG / Documents
# RAG_CHUNK_MAX_TOKENS=600
# RAG_CHUNK_OVERLAP_TOKENS=40
# RAG_EMBEDDER_TIMEOUT_MS=600000
# RAG_EMBEDDER_BATCH_SIZE=200
# RAG_EMBEDDER_CONCURRENCY=4
# RAG_EMBEDDER_PATH=/embed
# RAG_SIMILARITY_LIMIT=5
# RAG_HYBRID_SEARCH=true          # Enable hybrid BM25+vector search with RRF (requires migration 0011)
# RAG_HYBRID_CANDIDATES=20        # Number of candidates retrieved before MMR reranking
# RAG_MMR_LAMBDA=0.6              # MMR diversity balance: 1=pure relevance, 0=pure diversity
# ROLE_UPLOAD_MAX_FILE_SIZE=52428800
# DOCUMENT_ALLOWED_EXTENSIONS=.pdf,.docx,.txt,.md

# Memory Feature
# MEMORY_CACHE_TTL_SECONDS=300
# MEMORY_CACHE_PREFIX=memories
# MEMORY_EXTRACTION_MODEL=anthropic/claude-haiku-4-5
# MEMORY_MAX_MEMORIES=100
# MEMORY_TOP_K=10
# MEMORY_EXTRACTION_MIN_EXCHANGES=3
# MEMORY_EXTRACTION_EVERY_N_EXCHANGES=4
# MEMORY_FAILURE_PREFIX="Model request failed:"

# Models Configuration
# MODELS_JSON='[{"id":"fast-search","label":"Fast Search","category":"Presets","isPreset":true}]'
# DEFAULT_MODEL=anthropic/claude-haiku-4-5

# Email / SMTP (Optional: used for password reset)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=465
# SMTP_USER=your-username
# SMTP_PASSWORD=your-password
# SMTP_FROM="Complexity" <noreply@example.com>
# AUTH_RESET_EMAIL_SUBJECT="Reset your Complexity password"
# AUTH_RESET_EMAIL_FROM_DEFAULT='"Complexity" <noreply@complexity.local>'
